"""会话 + 认证(SM2-JWT/Redis seam) + 角色守卫。"""
from __future__ import annotations
import os
from typing import Iterator
from fastapi import Depends, Header, HTTPException, status
from pydantic import BaseModel
from sqlmodel import Session, create_engine

engine = create_engine(os.getenv("DATABASE_URL", "sqlite:///./dev.db"))


def get_session() -> Iterator[Session]:
    with Session(engine) as s:
        yield s


class User(BaseModel):
    sub: str
    name: str
    roles: list[str] = []


_ROLE_MAP = {"expert": "评审专家", "data": "数据管理员"}  # ascii→中文（header 不能含中文）


def get_current_user(authorization: str | None = Header(default=None)) -> User:
    if not authorization or not authorization.startswith("Bearer "):
        raise HTTPException(status.HTTP_401_UNAUTHORIZED, "缺少令牌")
    token = authorization.removeprefix("Bearer ").strip()
    # —— 替换点：SM2-JWT 验签(tongsuopy) + Redis token 白名单 ——
    if token.startswith("demo:"):
        code = token.split(":", 1)[1] or "expert"
        return User(sub="u-demo", name="演示", roles=[_ROLE_MAP.get(code, code)])
    raise HTTPException(status.HTTP_401_UNAUTHORIZED, "无效令牌")


def require_roles(*roles: str):
    def _g(user: User = Depends(get_current_user)) -> User:
        if roles and not (set(roles) & set(user.roles)):
            raise HTTPException(status.HTTP_403_FORBIDDEN, "角色不足")
        return user
    return _g
