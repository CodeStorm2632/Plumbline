# 复制为 .env 并按需填写。生产务必替换密钥。
ENV=prod
DATABASE_URL=postgresql+psycopg://app:app@db:5432/app
REDIS_URL=redis://redis:6379/0

# 国密（生产必填，tongsuopy 验签/字段加密用）
SM2_PRIVATE_KEY=
SM2_PUBLIC_KEY=
SM4_KEY=0123456789abcdef

# 安全策略
JWT_TTL=3600
MAX_FAILED_ATTEMPTS=5
LOCK_MINUTES=30
CAPTCHA_TTL=300

# 可选
SENTRY_DSN=

# —— 生产部署（主机 .env 用；CI 经 GitHub Secrets 注入 SSH_* ）——
APP_DOMAIN=plumbline.example.com
ACME_EMAIL=ops@example.com
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/plumbline       # → ghcr.io/your-org/plumbline-backend:TAG
IMAGE_TAG=latest
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app
